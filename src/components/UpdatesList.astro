---
// src/components/UpdatesList.astro
import PageBanner from "./PageBanner.astro";

const { lang, updates, ui } = Astro.props;

const slugs = {
  en: 'updates',
  es: 'actualizaciones',
  ru: 'obnovleniya',
};
const currentSlug = slugs[lang];
const prefix = lang === 'en' ? '' : `/${lang}`;

// 日期格式化
function formatDate(dateStr) {
  const d = new Date(dateStr);
  if (lang === 'ru') return d.toLocaleDateString('ru-RU');
  if (lang === 'es') return d.toLocaleDateString('es-ES');
  return d.toLocaleDateString('en-US');
}
---

<PageBanner
  title={ui.updates}
  breadcrumb={[
    { label: ui.home, href: lang === 'en' ? '/' : `/${lang}` },
    { label: ui.updates }
  ]}
  background="https://img.titan-recycling.com/wp-content/uploads/2026/04/background-metal-recycling-machine.webp"
/>

<section class="rs-postbox-area section-space">
  <div class="container">
    <div class="row g-5">
      <div class="col-xl-8 col-lg-8">
        <div class="rs-postbox-wrapper">
          {updates.map(update => (
            <article class="rs-postbox-item">
              <div class="rs-postbox-thumb">
                <a href={`${prefix}/${currentSlug}/${update.id}`}>
                  <img src={update.image} alt={update.title} />
                </a>
                <div class="rs-postbox-tag">
                  <a href={`${prefix}/${currentSlug}/${update.id}`}>{update.category}</a>
                </div>
              </div>
              <div class="rs-postbox-content">
                <div class="rs-postbox-meta-list">
                  <div class="rs-postbox-meta-item">
                    <span class="rs-meta-text">{ui.by} <a class="meta-author" href={`${prefix}/${currentSlug}/${update.id}`}>{update.author}</a></span>
                  </div>
                  <div class="rs-postbox-meta-item">
                    <span class="rs-postbox-meta-text"><a href={`${prefix}/${currentSlug}/${update.id}`}>{formatDate(update.date)}</a></span>
                  </div>
                </div>
                <h3 class="rs-postbox-title">
                  <a href={`${prefix}/${currentSlug}/${update.id}`}>{update.title}</a>
                </h3>
                <div class="rs-postbox-text">
                  <p>{update.summary}</p>
                </div>
                <div class="rs-postbox-btn">
                  <a class="rs-btn has-theme-blue has-icon has-bg" href={`${prefix}/${currentSlug}/${update.id}`}>
                    {ui.continueReading}
                    <span class="icon-box">
                      <svg class="icon-first" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32">
                        <path d="M31.71,15.29l-10-10L20.29,6.71,28.59,15H0v2H28.59l-8.29,8.29,1.41,1.41,10-10A1,1,0,0,0,31.71,15.29Z"></path>
                      </svg>
                      <svg class="icon-second" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32">
                        <path d="M31.71,15.29l-10-10L20.29,6.71,28.59,15H0v2H28.59l-8.29,8.29,1.41,1.41,10-10A1,1,0,0,0,31.71,15.29Z"></path>
                      </svg>
                    </span>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="col-xl-4 col-lg-4">
        <div class="rs-sidebar-wrapper rs-sidebar-sticky">
          <div class="sidebar-widget mb-30">
            <div class="sidebar-search">
              <form action="#">
                <div class="sidebar-search-input">
                  <input type="text" placeholder={ui.search}>
                  <button type="submit">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M8.11111 15.2222C12.0385 15.2222 15.2222 12.0385 15.2222 8.11111C15.2222 4.18375 12.0385 1 8.11111 1C4.18375 1 1 4.18375 1 8.11111C1 12.0385 4.18375 15.2222 8.11111 15.2222Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                      <path d="M16.9995 17L13.1328 13.1333" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                  </button>
                </div>
              </form>
            </div>
          </div>

          <div class="sidebar-widget widget-categories-two mb-30">
            <h5 class="sidebar-widget-title">{ui.categories}</h5>
            <div class="sidebar-widget-content">
              <div class="list">
                <ul>
                  {[...new Set(updates.map(u => u.category).filter(Boolean))].map(cat => (
                    <li>
                      <a href={`${prefix}/${currentSlug}?category=${cat}`}>{cat} <i class="ri-arrow-right-line"></i></a>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>

          <div class="sidebar-widget mb-30">
            <h5 class="sidebar-widget-title">{ui.latestPosts}</h5>
            <div class="sidebar-widget-content">
              <div class="sidebar-blog-item-wrapper">
                {updates.slice(0, 4).map(update => (
                  <div class="sidebar-blog-item">
                    <div class="sidebar-blog-thumb">
                      <a href={`${prefix}/${currentSlug}/${update.id}`}>
                        <img src={update.image} alt={update.title} />
                      </a>
                    </div>
                    <div class="sidebar-blog-content">
                      <h6 class="sidebar-blog-title">
                        <a href={`${prefix}/${currentSlug}/${update.id}`}>{update.title}</a>
                      </h6>
                      <div class="sidebar-blog-meta">
                        <i class="ri-calendar-line"></i>
                        <span>{formatDate(update.date)}</span>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.rs-postbox-title a:hover { color: var(--rs-theme-blue) !important; }
.rs-postbox-tag a { background-color: var(--rs-theme-blue) !important; color: #fff !important; }
.widget-categories-two ul li a:hover { background-color: var(--rs-theme-blue) !important; color: #fff !important; }
.widget-categories-two ul li a:hover i { color: #fff !important; }
.sidebar-blog-title a:hover { color: var(--rs-theme-blue) !important; }
</style>