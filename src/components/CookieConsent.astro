---
import { STATIC_PAGES } from "../config/site";

const { lang, currentContentId } = Astro.props;
---

<div class="cookie-overlay" id="cookieConsentModal" style="display:none;">
  <div class="cookie-panel">
    <h2 id="cookieConsentTitle"></h2>
    <p id="cookieConsentDesc"></p>
    <div class="cookie-top-row">
      <a href={STATIC_PAGES['privacy-policy'][lang]} id="cookieConsentPrivacyLink"></a>
      <select id="cookieConsentLang" onchange="window._cookieSetLang(this.value)">
        <option value="en" selected={lang === 'en'}>English</option>
        <option value="es" selected={lang === 'es'}>Español</option>
        <option value="ru" selected={lang === 'ru'}>русский</option>
      </select>
    </div>
    <div class="cookie-options">
      <label class="cookie-option">
        <div><strong id="cookieConsentEssentialTitle"></strong><small id="cookieConsentEssentialDesc"></small><em id="cookieConsentEssentialRequired"></em></div>
        <span class="toggle-switch"><input type="checkbox" checked disabled><span class="toggle-slider"></span></span>
      </label>
      <label class="cookie-option">
        <div><strong id="cookieConsentAnalyzeTitle"></strong><small id="cookieConsentAnalyzeDesc"></small></div>
        <span class="toggle-switch"><input type="checkbox" checked><span class="toggle-slider"></span></span>
      </label>
      <label class="cookie-option">
        <div><strong id="cookieConsentPersonalizedTitle"></strong><small id="cookieConsentPersonalizedDesc"></small></div>
        <span class="toggle-switch"><input type="checkbox" checked><span class="toggle-slider"></span></span>
      </label>
      <label class="cookie-option">
        <div><strong id="cookieConsentMarketingTitle"></strong><small id="cookieConsentMarketingDesc"></small></div>
        <span class="toggle-switch"><input type="checkbox" checked><span class="toggle-slider"></span></span>
      </label>
    </div>
    <div class="cookie-actions">
      <button class="cookie-btn primary" id="btnConsentAcceptAll"></button>
      <button class="cookie-btn outline" id="btnConsentStrictlyNecessary"></button>
      <button class="cookie-btn outline" id="btnConsentSaveSettings"></button>
    </div>
  </div>
</div>

<style is:global>
  @import "../styles/cookie.css";
</style>

<script is:inline>
  const initCookieConsent = async (forceOpen = false) => {
    if (!forceOpen && localStorage.getItem('cookieConsent')) return;

    const res = await fetch('/data/cookie-i18n.json');
    const translations = await res.json();

    const ids = {
      cookieConsentTitle: 'title',
      cookieConsentDesc: 'desc',
      cookieConsentPrivacyLink: 'privacy',
      cookieConsentEssentialTitle: 'essentialTitle',
      cookieConsentEssentialDesc: 'essentialDesc',
      cookieConsentEssentialRequired: 'essentialRequired',
      cookieConsentAnalyzeTitle: 'analyzeTitle',
      cookieConsentAnalyzeDesc: 'analyzeDesc',
      cookieConsentPersonalizedTitle: 'personalizedTitle',
      cookieConsentPersonalizedDesc: 'personalizedDesc',
      cookieConsentMarketingTitle: 'marketingTitle',
      cookieConsentMarketingDesc: 'marketingDesc',
      btnConsentAcceptAll: 'acceptAll',
      btnConsentStrictlyNecessary: 'strictlyNecessary',
      btnConsentSaveSettings: 'saveSettings',
    };

    const langSelect = document.getElementById('cookieConsentLang');
    const opts = langSelect.querySelectorAll('option');

    function syncLangSelectUI() {
      if (window.jQuery && typeof window.jQuery.fn?.niceSelect === 'function') {
        window.jQuery(langSelect).niceSelect('update');
      }
    }

    function setLang(lang) {
      const t = translations[lang];
      if (!t) return;
      Object.entries(ids).forEach(([elId, key]) => {
        const el = document.getElementById(elId);
        if (el) el.textContent = t[key] || '';
      });
      if (opts[0]) opts[0].textContent = t.langEn || 'English';
      if (opts[1]) opts[1].textContent = t.langEs || 'Español';
      if (opts[2]) opts[2].textContent = t.langRu || 'русский';

      // Ensure the correct option has the selected attribute for nice-select
      opts.forEach(opt => {
        if (opt.value === lang) {
          opt.selected = true;
          opt.setAttribute('selected', 'selected');
        } else {
          opt.selected = false;
          opt.removeAttribute('selected');
        }
      });

      syncLangSelectUI();
    }

    const currentSiteLang = window.__siteLanguage?.currentLang || document.documentElement.lang || 'en';
    langSelect.value = currentSiteLang;
    setLang(currentSiteLang);
    window._cookieSetLang = function(lang) {
      setLang(lang);
      window.__siteLanguage?.setPreferredSiteLang(lang);
    };

    document.getElementById('cookieConsentModal').style.display = 'flex';

    document.querySelectorAll('#btnConsentAcceptAll, #btnConsentStrictlyNecessary, #btnConsentSaveSettings').forEach(btn => {
      btn.addEventListener('click', () => {
        document.getElementById('cookieConsentModal').style.display = 'none';
        localStorage.setItem('cookieConsent', '1');

        const newLang = langSelect.value;
        window.__siteLanguage?.navigateToSiteLang(newLang);
      });
    });
  };

  window.openCookieConsentModal = () => {
    initCookieConsent(true);
  };

  const scheduleCookieConsent = () => {
    if ('requestIdleCallback' in window) {
      window.requestIdleCallback(() => initCookieConsent(), { timeout: 1500 });
    } else {
      window.setTimeout(() => initCookieConsent(), 300);
    }
  };

  if (document.readyState === 'complete') {
    scheduleCookieConsent();
  } else {
    window.addEventListener('load', scheduleCookieConsent, { once: true });
  }
</script>
