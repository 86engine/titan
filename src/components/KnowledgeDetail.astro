---
import PageBanner from "./PageBanner.astro";
import { getPageURL, buildBreadcrumb, getSubCategoryName } from "../data/site.js";

const { lang, knowledge, ui, parentContentId } = Astro.props;
---

<PageBanner
  title={knowledge.acf?.knowledge_h1 || knowledge.acf?.knowledge_name}
  breadcrumb={buildBreadcrumb(lang, [
    { label: ui.knowledge, href: getPageURL('knowledgeList', lang) },
    { label: getSubCategoryName(parentContentId, lang), href: getPageURL(parentContentId, lang) },
    { label: { en: 'Detail', es: 'Detalles', ru: 'Подробности' }[lang] || 'Detail' }
  ])}
  background={knowledge.acf?.knowledge_bg_img}
/>

<section class="rs-services-area section-space">
  <div class="container">
    <div class="rs-services-details-wrapper">

      {knowledge.blocks && knowledge.blocks.length > 0 && (
        knowledge.blocks.map((block, index) => (
          <>
            {block.type === 'video' ? (
              <>
                {block.title && (
                  <h2 class="rs-section-subtitle has-theme-blue" style="justify-content:left;margin-bottom:30px">{block.title}</h2>
                )}
                {block.topText && <div set:html={block.topText} />}
                <section class="rs-why-choose-area section-space rs-why-choose-one pt-0 pb-0">
                  <div class="container">
                    <div class="row align-items-xl-center g-5">
                      <div class="col-12 px-0">
                        <div style="position:relative;width:100%;">
                          <img src={block.videoImg} alt="video cover" style="width:100%;height:330px;object-fit:cover;display:block;" />
                          <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);">
                            <a href={block.video} class="rs-play-btn popup-video has-theme-blue"><i class="ri-play-fill"></i></a>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </section>
                {block.bottomText && <div set:html={block.bottomText} />}
              </>
            ) : block.type === 'carousel' ? (
              <>
                {block.title && (
                  <h2 class="rs-section-subtitle has-theme-blue" style="justify-content:left;margin-bottom:30px">{block.title}</h2>
                )}
                {block.topText && <div set:html={block.topText} />}
                <section class="rs-services-area section-space rs-services-nine rs-swiper pt-0 pb-0 px-0">
                  <div class="container">
                    <div class="col-12">
                      <div class="rs-services-slider-wrapper">
                        <div class="swiper" data-clone-slides="false" data-loop="false" data-speed="2000" data-autoplay="true" data-dots-dynamic="false" data-hover-pause="true" data-effect="false" data-delay="1000" data-item="3" data-item-xl="2" data-item-lg="2" data-item-md="2" data-item-sm="1" data-item-xs="1" data-item-mobile="1" data-margin="30">
                          <div class="swiper-wrapper process-counts">
                            {block.images && block.images.map((img, i) => (
                              <div class="swiper-slide">
                                <div class="rs-services-item">
                                  <div class="rs-services-thumb">
                                    <img src={typeof img === 'string' ? img : img.url || img.sizes?.large} alt={`${block.title || ''} ${i + 1}`} />
                                  </div>
                                </div>
                              </div>
                            ))}
                          </div>
                          <div class="rs-services-pagination">
                            <div class="swiper-pagination rs-pagination has-theme-blue"></div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </section>
                {block.bottomText && <div set:html={block.bottomText} />}
              </>
            ) : block.type === 'faq' ? (
              <>
                {block.title && (
                  <h2 class="rs-section-subtitle has-theme-blue" style="justify-content:left;margin-bottom:30px">{block.title}</h2>
                )}
                <div class="rs-faq-content rs-accordion-one has-theme-blue">
                  <div class="accordion-wrapper">
                    <div class="accordion" id={`accordionExample-${index}`}>
                      {block.faqs && block.faqs.map((faq, i) => (
                        <div class="rs-accordion-item">
                          <h4 class="accordion-header" id={`heading-${index}-${i}`}>
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target={`#collapse-${index}-${i}`} aria-expanded={i === 0 ? 'true' : 'false'} aria-controls={`collapse-${index}-${i}`}>
                              {faq.knowledge_faq_title}
                              <span class="accordion-btn"></span>
                            </button>
                          </h4>
                          <div id={`collapse-${index}-${i}`} class={`accordion-collapse collapse ${i === 0 ? 'show' : ''}`} data-bs-parent={`#accordionExample-${index}`}>
                            <div class="accordion-body" set:html={faq.knowledge_faq_content} />
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              </>
            ) : (
              <>
                {block.title && (
                  <h2 class="rs-section-subtitle has-theme-blue" style="justify-content:left;margin-bottom:30px">{block.title}</h2>
                )}
                {block.topText && (
                  <div class="detail-left__html" style="margin-bottom:30px" set:html={block.topText} />
                )}
                {block.image && block.middleText && (
                  <div style="display: flex; gap: 30px; align-items: flex-start; margin-bottom: 25px;">
                    {index % 2 === 0 ? (
                      <>
                        <div style="flex: 1 1 55%; min-width: 280px;">
                          <div set:html={block.middleText} />
                        </div>
                        <div style="flex: 0 0 45%; max-width: 45%;">
                          <img src={block.image} alt={block.title || ''} style="border-radius: 24px; width: 100%;" />
                        </div>
                      </>
                    ) : (
                      <>
                        <div style="flex: 0 0 45%; max-width: 45%;">
                          <img src={block.image} alt={block.title || ''} style="border-radius: 24px; width: 100%;" />
                        </div>
                        <div style="flex: 1 1 55%; min-width: 280px;">
                          <div set:html={block.middleText} />
                        </div>
                      </>
                    )}
                  </div>
                )}
                {block.image && !block.middleText && (
                  <div class="rs-services-details-thumb mt-25 mb-25">
                    <img src={block.image} alt={block.title || ''}>
                  </div>
                )}
                {!block.image && block.middleText && (
                  <div class="mb-20" set:html={block.middleText} />
                )}
                {block.bottomText && (
                  <div class="mb-20" set:html={block.bottomText} />
                )}
              </>
            )}
          </>
        ))
      )}

    </div>
  </div>
</section>