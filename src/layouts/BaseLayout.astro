---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { LANGS } from "../config/site";
import { getPageURL, getTranslationsByContentId } from "../data/site.js";
import "../styles/main.css";

const {
  lang,
  currentContentId,
  title,
  description,
  keywords,
  preloadImages = []
} = Astro.props;

const siteUrl = 'https://titan-recycling.com';

const translations = getTranslationsByContentId(currentContentId);
const pageUrls = Object.fromEntries(
  LANGS.map((language) => [language, getPageURL(currentContentId, language)])
);

const alternates = {};
if (translations) {
  for (const l of LANGS) {
    if (translations[l]?.link) {
      alternates[l] = translations[l].link;
    }
  }
}

const canonical = alternates[lang] || `${siteUrl}/`;
---

<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title || 'TITAN | Metal Recycling Equipment Manufacturer'}</title>
    {description && <meta name="description" content={description} />}
    {keywords && <meta name="keywords" content={keywords} />}

    <link rel="canonical" href={canonical} />

    {alternates.en && <link rel="alternate" hreflang="en" href={alternates.en} />}
    {alternates.es && <link rel="alternate" hreflang="es" href={alternates.es} />}
    {alternates.ru && <link rel="alternate" hreflang="ru" href={alternates.ru} />}
    {alternates.en && <link rel="alternate" hreflang="x-default" href={alternates.en} />}

    <script is:inline define:vars={{ lang, pageUrls }}>
      (() => {
        const STORAGE_KEY = 'siteLang';
        const LEGACY_STORAGE_KEY = 'cookieLang';
        const supportedLangs = ['en', 'es', 'ru'];
        const fallbackUrls = { en: '/', es: '/es/', ru: '/ru/' };

        const normalizeLang = (value) => supportedLangs.includes(value) ? value : '';
        const safeGetItem = (key) => {
          try {
            return window.localStorage.getItem(key);
          } catch {
            return null;
          }
        };
        const safeSetItem = (key, value) => {
          try {
            window.localStorage.setItem(key, value);
          } catch {
            // 忽略本地存储不可用场景
          }
        };

        const getPreferredSiteLang = () => (
          normalizeLang(safeGetItem(STORAGE_KEY)) ||
          normalizeLang(safeGetItem(LEGACY_STORAGE_KEY)) ||
          ''
        );

        const setPreferredSiteLang = (targetLang) => {
          const normalizedLang = normalizeLang(targetLang) || 'en';
          safeSetItem(STORAGE_KEY, normalizedLang);
          safeSetItem(LEGACY_STORAGE_KEY, normalizedLang);
          return normalizedLang;
        };

        const resolveUrl = (targetLang) => pageUrls?.[targetLang] || fallbackUrls[targetLang] || '/';

        const navigateToSiteLang = (targetLang, options = {}) => {
          const normalizedLang = setPreferredSiteLang(targetLang);
          const target = resolveUrl(normalizedLang);
          if (!target) return normalizedLang;

          const currentUrl = new URL(window.location.href);
          const targetUrl = new URL(target, window.location.origin);
          if (
            currentUrl.pathname === targetUrl.pathname &&
            currentUrl.search === targetUrl.search &&
            currentUrl.hash === targetUrl.hash
          ) {
            return normalizedLang;
          }

          if (options.replace) {
            window.location.replace(targetUrl.toString());
          } else {
            window.location.assign(targetUrl.toString());
          }
          return normalizedLang;
        };

        window.__siteLanguage = {
          currentLang: lang,
          fallbackUrls,
          pageUrls,
          getPreferredSiteLang,
          navigateToSiteLang,
          resolveUrl,
          setPreferredSiteLang,
        };

        document.addEventListener('click', (event) => {
          const switcher = event.target.closest('a[data-site-lang-switch]');
          if (!switcher) return;
          const targetLang = switcher.dataset.siteLangSwitch;
          if (!targetLang) return;
          setPreferredSiteLang(targetLang);
        });

        const preferredSiteLang = getPreferredSiteLang();
        if (!preferredSiteLang || preferredSiteLang === lang) return;

        const target = resolveUrl(preferredSiteLang);
        if (!target) return;

        const currentUrl = new URL(window.location.href);
        const targetUrl = new URL(target, window.location.origin);
        if (
          currentUrl.pathname === targetUrl.pathname &&
          currentUrl.search === targetUrl.search &&
          currentUrl.hash === targetUrl.hash
        ) {
          return;
        }

        window.location.replace(targetUrl.toString());
      })();
    </script>

    <link rel="dns-prefetch" href="https://img.titan-recycling.com" />
    <link rel="preconnect" href="https://img.titan-recycling.com" crossorigin />
    {preloadImages.map((href) => (
      <link rel="preload" as="image" href={href} />
    ))}

    <link rel="stylesheet" href="/css/vendor/bootstrap.min.css">
    <link rel="stylesheet" href="/css/plugins/swiper.min.css">
    <link rel="stylesheet" href="/css/plugins/nice-select.css">
    <link rel="stylesheet" href="/css/vendor/magnific-popup.css">
    <link rel="stylesheet" href="/css/vendor/fontawesome-pro.css">
    <link rel="stylesheet" href="/css/vendor/spacing.css">
    <style is:global>
      [data-no-copy-detail] {
        -webkit-user-select: none;
        -moz-user-select: none;
        user-select: none;
        -webkit-touch-callout: none;
      }
    </style>
  </head>
  
  <body>
    <Header lang={lang} currentContentId={currentContentId} />
    <main><slot /></main>
    <Footer lang={lang} />
    <script is:inline defer src="/js/vendor/jquery-3.7.1.min.js"></script>
    <script is:inline defer src="/js/accordion.js"></script>
    <script is:inline defer src="/js/plugins/meanmenu.min.js"></script>
    <script is:inline defer src="/js/plugins/swiper.min.js"></script>
    <script is:inline defer src="/js/vendor/magnific-popup.min.js"></script>
    <script is:inline defer src="/js/plugins/nice-select.min.js"></script>
    <script is:inline defer src="/js/plugins/jarallax.min.js"></script>
    <script is:inline defer src="/js/vendor/ajax-form.js"></script>
    <script is:inline defer src="/js/plugins/parallax-effect.min.js"></script>
    <script is:inline defer src="/js/main.js"></script>
    <script is:inline>
      (() => {
        const getDetailRoot = (target) => {
          if (!(target instanceof Element)) return null;
          return target.closest('[data-no-copy-detail]');
        };

        document.addEventListener('copy', (event) => {
          if (!getDetailRoot(event.target)) return;
          event.preventDefault();
        }, true);

        document.addEventListener('cut', (event) => {
          if (!getDetailRoot(event.target)) return;
          event.preventDefault();
        }, true);

        document.addEventListener('selectstart', (event) => {
          if (!getDetailRoot(event.target)) return;
          event.preventDefault();
        }, true);

        document.addEventListener('contextmenu', (event) => {
          if (!getDetailRoot(event.target)) return;
          event.preventDefault();
        }, true);

        document.addEventListener('keydown', (event) => {
          if (!(event.ctrlKey || event.metaKey)) return;
          if (!['a', 'c', 'x'].includes(event.key.toLowerCase())) return;

          const activeElement = document.activeElement;
          const source = activeElement instanceof Element ? activeElement : event.target;
          if (!getDetailRoot(source)) return;

          event.preventDefault();
        }, true);
      })();
    </script>
  </body>
</html>
