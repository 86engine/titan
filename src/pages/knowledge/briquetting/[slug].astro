---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import KnowledgeDetail from "../../../components/KnowledgeDetail.astro";
import { getKnowledge } from "../../../data/knowledge.js";
import { buildContentIndex } from "../../../lib/wordpress.js";

export async function getStaticPaths() {
  const all = await getKnowledge('en');
  const filtered = all.filter(k => k.knowledgeType === 'briquetting');
  return filtered.map(k => ({ params: { slug: k.id }, props: { knowledge: k } }));
}

const lang = 'en';
const type = 'briquetting';
const { knowledge } = Astro.props;

if (!knowledge) return Astro.redirect('/knowledge/briquetting');

const allKnowledge = await getKnowledge('en');
const contentIndex = buildContentIndex(allKnowledge);

const ui = {
  en: { home: 'Home', knowledge: 'Knowledge', detail: 'Detail' },
};

const alternates = contentIndex[knowledge.content_id] || {};
---

<BaseLayout 
  lang={lang} 
  translations={knowledge.translations} 
  contentIndex={contentIndex} 
  currentContentId={knowledge.content_id}
  title={knowledge.pageTitle}
  description={knowledge.pageDescription}
  keywords={knowledge.pageKeywords}
  alternates={alternates}
>
  <KnowledgeDetail lang={lang} type={type} knowledge={knowledge} ui={ui.en} />
</BaseLayout>