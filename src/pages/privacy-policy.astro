---
import BaseLayout from "../layouts/BaseLayout.astro";
import CookieConsent from "../components/CookieConsent.astro";
import { STATIC_PAGES } from "../config/site";
import { buildBreadcrumb } from "../data/site.js";

const lang = 'en';

const title = 'Cookie Policy | TITAN';
---

<BaseLayout
  lang={lang}
  currentContentId="privacy-policy"
  title={title}
>
  <section class="rs-breadcrumb-area rs-breadcrumb-one p-relative">
    <div class="rs-breadcrumb-bg" style="background-image: url('https://img.titan-recycling.com/wp-content/uploads/2026/06/news-detail.webp');"></div>
    <div class="container">
      <div class="row">
        <div class="col-xxl-6 col-xl-8 col-lg-8">
          <div class="rs-breadcrumb-content-wrapper">
            <div class="rs-breadcrumb-title-wrapper">
              <h1 class="rs-breadcrumb-title">Cookie Policy</h1>
            </div>
            <div class="rs-breadcrumb-menu">
              <nav>
                <ul>
                  {buildBreadcrumb(lang, [{ label: 'Cookie Policy' }]).map((item, i) => (
                    <li><span>
                      {item.href ? <a href={item.href}>{item.label}</a> : item.label}
                    </span></li>
                  ))}
                </ul>
              </nav>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="rs-postbox-area section-space">
    <div class="container">
      <div class="row g-5">
        <div class="col-xl-8 col-lg-8 cookie-content" style="margin:0 auto;float:none;">
          <div class="rs-postbox-details-wrapper content">
            <p class="last-updated">last updated: 2026-04-18</p>
            <section><h2>1. What is a Cookie?</h2><p>Cookies are small text files that are stored on your device (computer, smartphone, tablet, etc.) when you browse most websites. Except in some cases, cookies require your consent to be stored on your device.</p><p>You can manage your preferences by changing all or some of the cookie settings below. You can also allow or disable all cookies.</p></section>
            <section><h2>2. What information do we collect?</h2><p>The cookies we store on your device with your consent enable us to collect the following information:</p><h3>2.1 Information related to the device you are using:</h3><ul><li>The type of device you are using (smartphone, tablet, computer, etc.);</li><li>The operating system of your device (macOS, iOS, Android, Windows, BlackBerry, etc.);</li><li>The type and version of plug-ins for your device;</li><li>The browser used (Safari, Chrome, Internet Explorer, etc.);</li><li>The IP address of your device;</li><li>Your device's geolocation data;</li><li>Your language preference.</li></ul><h3>2.2 Browsing and user behavior data:</h3><ul><li>Traffic statistics for individual pages of our website;</li><li>The full URL paths to, through and from our site;</li><li>Details of any advertisements that have been served to you;</li><li>Your interaction with those ads;</li><li>The action you took after clicking on an ad;</li><li>The number of times you have received placed advertisements;</li><li>Personal information related to your activities online.</li></ul></section>
            <section><h2>3. Basic Cookies</h2><p>These cookies are necessary for the proper functioning of the website. Their settings cannot be changed.</p><p>These basic cookies do not require your consent.</p></section>
            <section><h2>4. Performance Cookies</h2><p>These cookies count and analyze the number of visitors to our website in order to improve the performance of the site.</p><p>These cookies require your prior consent.</p></section>
            <section><h2>5. Advertising and Social Media Cookies</h2><p>These cookies are used to customize our advertisements on third-party websites based on your preferences.</p><p>These cookies require your prior consent.</p></section>
            <section><h2>6. Third Party Cookies</h2><p>As our website contains third-party applications, our partners may set cookies.</p><p>These cookies require your prior consent.</p></section>
            <section><h2>7. What are these cookies used for and how long are they stored?</h2>
              <div class="table-responsive">
                <table class="cookie-table">
                  <thead><tr><th>Type of Cookie</th><th>Name</th><th>Purpose</th><th>Cookie Duration</th></tr></thead>
                  <tbody><tr><td>Basic Cookie</td><td>Cookie consent</td><td>Checks if the user has accepted cookies</td><td>100 days</td></tr><tr><td>Performance Cookie</td><td></td><td>Google Analytics session ID storage</td><td>2 years</td></tr><tr><td>Advertising Cookie</td><td>Cookie consent to Google</td><td>Checks if user agrees to Google's policies</td><td>1 year</td></tr></tbody>
                </table>
              </div>
            </section>
            <section><h2>8. Your Cookie Preferences</h2><p>We collect and process your data on this website to better understand its use. We will always ask for your consent. You can change your privacy settings here.</p><p>In addition, you can block the setting of cookies by adjusting your browser settings. Please note that disabling cookies will affect the functionality of this website as well as many other websites you visit.</p>
              <button id="cookieSettingsBtn" class="rs-btn blue-bg cookie-settings-btn">Settings</button>
            </section>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<CookieConsent lang={lang} />

<style>
  .cookie-settings-btn { font-size: 16px; padding: 10px 30px; height: auto; width: auto; }
</style>

<script is:inline>
  document.getElementById('cookieSettingsBtn')?.addEventListener('click', () => {
    if (window.openCookieConsentModal) {
      window.openCookieConsentModal();
    }
  });
</script>