---
import BaseLayout from "../layouts/BaseLayout.astro";
import AboutPage from "../components/AboutPage.astro";
import { getAbout } from "../data/about.js";

const lang = 'en';

const about = await getAbout(lang);

const pageTranslations = {};
for (const [l, data] of Object.entries(about.translations || {})) {
  if (data?.link) {
    pageTranslations[l] = { url: new URL(data.link).pathname };
  }
}

const ui = {
  home: 'Home',
  about: 'About TITAN',
  aboutLabel: 'ABOUT TITAN',
  aboutTitle: 'Welcome to TITAN, where advanced recycling technology meets practical solutions, helping you turn metal scrap into real value.',
  missionTitle: 'Our Mission',
  missionDesc: 'To help our customers turn metal scrap into value by delivering efficient, cost-effective and reliable recycling equipment.',
  visionTitle: 'Our Vision',
  visionDesc: 'To be the first choice for metal recycling solutions by continuously improving technology, service and customer satisfaction.',
};

const alternates = {
  en: '/about',
  es: '/es/sobre-nosotros',
  ru: '/ru/o-kompanii',
};
---

<BaseLayout 
  lang={lang} 
  translations={pageTranslations}
  title={about.pageTitle} 
  description={about.pageDescription} 
  keywords={about.pageKeywords}
  alternates={alternates}
>
  <AboutPage lang={lang} about={about} ui={ui} />
</BaseLayout>