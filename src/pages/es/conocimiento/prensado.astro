---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import KnowledgeSubList from "../../../components/KnowledgeSubList.astro";
import { getKnowledge } from "../../../data/knowledge.js";
import { getKnowledgeCategory } from "../../../data/knowledgeCategories.js";
import { getKnowledgeIdsBySubCategory } from "../../../data/site.js";
import headerI18n from "../../../../public/data/header-i18n.json" with { type: 'json' };

const lang = 'es';
const type = 'baling';
const currentContentId = 'knowledgeList-baler';

const [allKnowledge, pageData] = await Promise.all([
  getKnowledge(lang),
  getKnowledgeCategory(lang, type),
]);

const subKnowledgeIds = getKnowledgeIdsBySubCategory(currentContentId);
const knowledgeList = allKnowledge.filter(item => subKnowledgeIds.includes(item.content_id));

const ui = headerI18n[lang] || headerI18n.en;
---

<BaseLayout
  lang={lang}
  currentContentId={currentContentId}
  title={pageData.pageTitle}
  description={pageData.pageDescription}
  keywords={pageData.pageKeywords}
>
  <KnowledgeSubList lang={lang} knowledgeList={knowledgeList} pageData={pageData} ui={ui} currentContentId={currentContentId} parentContentId="knowledgeList" />
</BaseLayout>