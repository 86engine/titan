---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import UpdatesDetail from "../../../components/UpdatesDetail.astro";
import { getUpdates } from "../../../data/updates.js";
import { buildContentIndex } from "../../../lib/wordpress.js";

export async function getStaticPaths() {
  const updates = await getUpdates('es');
  return updates.map(u => ({ params: { slug: u.id }, props: { update: u } }));
}

const lang = 'es';
const { update } = Astro.props;

if (!update) return Astro.redirect('/es/actualizaciones');

const allUpdates = await getUpdates('es');
const contentIndex = buildContentIndex(allUpdates);

const ui = {
  home: 'Inicio', updates: 'Actualizaciones', detail: 'Detalle', by: 'Por', recommended: 'Recomendado',
};

const alternates = contentIndex[update.content_id] || {};
---

<BaseLayout 
  lang={lang} 
  translations={update.translations} 
  contentIndex={contentIndex} 
  currentContentId={update.content_id}
  title={update.pageTitle}
  description={update.pageDescription}
  keywords={update.pageKeywords}
  alternates={alternates}
>
  <UpdatesDetail lang={lang} update={update} ui={ui} />
</BaseLayout>