---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactPage from "../../components/ContactPage.astro";

const lang = 'es';

const pageTranslations = {
  en: { url: '/contact' },
  es: { url: '/es/contacto' },
  ru: { url: '/ru/kontakty' },
};

const ui = {
  home: 'Inicio',
  pageTitle: 'Contacto',
  globalBranch: 'Contáctanos',
  heading: 'Póngase en contacto con nuestro equipo',
  subheading: '¡Podemos ofrecerle soluciones profesionales para ayudarle a resolver problemas en el proceso de producción!',
  locationTitle: 'Nuestra Ubicación',
  locationDesc: 'N.º 1 Dongde Road, Zona de Alta Tecnología, Jiangyin, Jiangsu, China',
  chatTitle: 'Chatear con Soporte',
  mailto:'aaron@titan-recycling.com',
  callTitle: 'Llámanos',
  phone:'+86 183 6080 9300',
  formTitle: 'Contáctanos',
  formDesc: 'Nuestro equipo está aquí para responder cualquier pregunta que tenga',
  namePlaceholder: 'Nombre Completo',
  emailPlaceholder: 'Correo Electrónico',
  phonePlaceholder: 'Teléfono',
  messagePlaceholder: 'Escriba Su Mensaje',
  sendBtn: 'Enviar Mensaje',
  nameRequired: 'Por favor ingrese su nombre',
  emailRequired: 'Por favor ingrese su correo electrónico o número de teléfono',
  messageRequired: 'Por favor ingrese su mensaje',
};

const title = 'Contactar con TITAN | Fabricante de Equipos de Reciclaje de Metales';
const description = 'Contacte con TITAN para soluciones de equipos de reciclaje de metales, soporte técnico y cotizaciones. Obtenga una respuesta rápida de nuestro equipo de ingeniería.';
const keywords = 'fabricante de equipos de reciclaje de metales,proveedor de equipos de reciclaje de metales';

const alternates = {
  en: '/contact',
  es: '/es/contacto',
  ru: '/ru/kontakty',
};
---

<BaseLayout 
  lang={lang} 
  translations={pageTranslations}
  title={title} 
  description={description} 
  keywords={keywords}
  alternates={alternates}
>
  <ContactPage lang={lang} ui={ui} />
</BaseLayout>