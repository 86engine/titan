---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AboutPage from "../../components/AboutPage.astro";
import { getAbout } from "../../data/about.js";

const lang = 'es';

const about = await getAbout(lang);

const pageTranslations = {};
for (const [l, data] of Object.entries(about.translations || {})) {
  if (data?.link) {
    pageTranslations[l] = { url: new URL(data.link).pathname };
  }
}

const ui = {
  home: 'Inicio',
  about: 'Sobre nosotros',
  aboutLabel: 'SOBRE NOSOTROS',
  aboutTitle: 'Bienvenido a TITAN, donde la tecnología avanzada de reciclaje se une a soluciones prácticas, ayudándole a convertir la chatarra en valor real.',
  missionTitle: 'Nuestra Misión',
  missionDesc: 'Ayudar a nuestros clientes a convertir la chatarra en valor mediante equipos de reciclaje eficientes, rentables y fiables.',
  visionTitle: 'Nuestra Visión',
  visionDesc: 'Ser la primera opción en soluciones de reciclaje de metales mejorando continuamente la tecnología, el servicio y la satisfacción del cliente.',
};

const alternates = {
  en: '/about',
  es: '/es/sobre-nosotros',
  ru: '/ru/o-kompanii',
};
---

<BaseLayout 
  lang={lang} 
  translations={pageTranslations}
  title={about.pageTitle} 
  description={about.pageDescription} 
  keywords={about.pageKeywords}
  alternates={alternates}
>
  <AboutPage lang={lang} about={about} ui={ui} />
</BaseLayout>