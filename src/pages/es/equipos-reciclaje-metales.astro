---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductList from "../../components/ProductList.astro";
import { getProducts } from "../../data/products.js";
import { getProductCategories } from "../../data/productCategories.js";
import headerI18n from "../../../public/data/header-i18n.json" with { type: 'json' };

const lang = 'es';

const [products, productCategories] = await Promise.all([
  getProducts(lang),
  getProductCategories(lang),
]);

const ui = headerI18n[lang] || headerI18n.en;
ui.viewDetail = { en: 'View Details', es: 'Ver Detalles', ru: 'Подробнее' }[lang] || 'View Details';
---

<BaseLayout
  lang={lang}
  currentContentId="productList"
  title={productCategories.pageTitle}
  description={productCategories.pageDescription}
  keywords={productCategories.pageKeywords}
>
  <ProductList lang={lang} products={products} productCategories={productCategories} ui={ui} />
</BaseLayout>