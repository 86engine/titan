---
import BaseLayout from "../layouts/BaseLayout.astro";
import ParentKnowledgeList from "../components/ParentKnowledgeList.astro";
import { getKnowledgeCategory } from "../data/parentKnowledge.js";

const lang = 'en';

const pageData = await getKnowledgeCategory(lang);

const pageTranslations = {};
for (const [l, data] of Object.entries(pageData.translations || {})) {
  if (data?.link) {
    pageTranslations[l] = { url: new URL(data.link).pathname };
  }
}

const ui = { home: 'Home', knowledge: 'Knowledge' };

const alternates = {
  en: '/knowledge',
  es: '/es/conocimiento',
  ru: '/ru/znaniya',
};
---

<BaseLayout 
  lang={lang} 
  translations={pageTranslations}
  title={pageData.pageTitle} 
  description={pageData.pageDescription} 
  keywords={pageData.pageKeywords}
  alternates={alternates}
>
  <ParentKnowledgeList lang={lang} pageData={pageData} ui={ui} />
</BaseLayout>