---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductDetail from "../../components/ProductDetail.astro";
import { getProducts } from "../../data/products.js";
import { buildContentIndex } from "../../lib/wordpress.js";

export async function getStaticPaths() {
  const products = await getProducts('en');
  return products.map(p => ({
    params: { slug: p.id },
    props: { product: p }
  }));
}

const lang = 'en';
const { product } = Astro.props;

if (!product) return Astro.redirect('/metal-recycling-equipment');

const allProducts = await getProducts('en');
const contentIndex = buildContentIndex(allProducts);

const ui = {
  en: { home: 'Home', products: 'Products', detail: 'Detail', download: 'Download', requestQuote: 'Request A Quote', contactUrl: '/contact#get-in-touch'},
};

const alternates = contentIndex[product.content_id] || {};
---

<BaseLayout 
  lang={lang} 
  translations={product.translations} 
  contentIndex={contentIndex} 
  currentContentId={product.content_id}
  title={product.pageTitle} 
  description={product.pageDescription} 
  keywords={product.pageKeywords}
  alternates={alternates}
>
  <ProductDetail lang={lang} product={product} ui={ui.en} />
</BaseLayout>