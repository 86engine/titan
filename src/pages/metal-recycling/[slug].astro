---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ApplicationDetail from "../../components/ApplicationDetail.astro";
import { getApplications } from "../../data/applications.js";
import { buildContentIndex } from "../../lib/wordpress.js";

export async function getStaticPaths() {
  const applications = await getApplications('en');
  return applications.map(a => ({
    params: { slug: a.id },
    props: { application: a }
  }));
}

const lang = 'en';
const { application } = Astro.props;

if (!application) return Astro.redirect('/metal-recycling');

const allApps = await getApplications('en');
const contentIndex = buildContentIndex(allApps);

const t = {
  en: { home: 'Home', applications: 'Solutions', detail: 'Detail' },
};
const ui = t[lang];

const alternates = contentIndex[application.content_id] || {};
---

<BaseLayout 
  lang={lang} 
  translations={application.translations} 
  contentIndex={contentIndex} 
  currentContentId={application.content_id}
  title={application.pageTitle} 
  description={application.pageDescription} 
  keywords={application.pageKeywords}
  alternates={alternates}
>
  <ApplicationDetail lang={lang} application={application} ui={ui} />
</BaseLayout>