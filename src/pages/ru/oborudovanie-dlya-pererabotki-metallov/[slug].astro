---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ProductDetail from "../../../components/ProductDetail.astro";
import { getProducts } from "../../../data/products.js";
import { buildContentIndex } from "../../../lib/wordpress.js";

export async function getStaticPaths() {
  const products = await getProducts('ru');
  return products.map(p => ({
    params: { slug: p.id },
    props: { product: p }
  }));
}

const lang = 'ru';
const { product } = Astro.props;

if (!product) return Astro.redirect('/oborudovanie-dlya-pererabotki-metallov');

const allProducts = await getProducts('ru');
const contentIndex = buildContentIndex(allProducts);

const ui = {
   ru: { home: 'Главная', products: 'Продукты', detail: 'Детали' , download: 'Скачать', requestQuote: 'Запросить цену',contactUrl: '/ru/kontakty#get-in-touch'}
};

const alternates = {
  en: product.translations?.en?.url || '#',
  es: product.translations?.es?.url || '#',
  ru: product.translations?.ru?.url || '#',
};
---

<BaseLayout 
  lang={lang} 
  translations={product.translations} 
  contentIndex={contentIndex} 
  currentContentId={product.content_id}
  title={product.pageTitle} 
  description={product.pageDescription} 
  keywords={product.pageKeywords}
  alternates={alternates}
>
  <ProductDetail lang={lang} product={product} ui={ui.ru} />
</BaseLayout>