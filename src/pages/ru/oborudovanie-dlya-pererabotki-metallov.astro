---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductList from "../../components/ProductList.astro";
import { getProducts } from "../../data/products.js";
import { getProductCategories } from "../../data/productCategories.js";

const lang = 'ru';

const [products, productCategories] = await Promise.all([
  getProducts(lang),
  getProductCategories(lang),
]);

// 把 WordPress link 转成 Astro 路径，传给 Header 做语言切换
const pageTranslations = {};
for (const [l, data] of Object.entries(productCategories.translations || {})) {
  if (data?.link) {
    pageTranslations[l] = { url: new URL(data.link).pathname };
  }
}

const ui = { home: 'Главная', products: 'Продукты', viewDetail: 'Подробнее' };

const alternates = {
  en: '/metal-recycling-equipment',
  es: '/es/equipos-reciclaje-metales',
  ru: '/ru/oborudovanie-dlya-pererabotki-metallov',
};
---

<BaseLayout 
  lang={lang} 
  translations={pageTranslations}
  title={productCategories.pageTitle} 
  description={productCategories.pageDescription} 
  keywords={productCategories.pageKeywords}
  alternates={alternates}
>
  <ProductList lang={lang} products={products} productCategories={productCategories} ui={ui} />
</BaseLayout>