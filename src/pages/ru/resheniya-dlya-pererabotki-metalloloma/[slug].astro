---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ApplicationDetail from "../../../components/ApplicationDetail.astro";
import { getApplications } from "../../../data/applications.js";
import headerI18n from "../../../../public/data/header-i18n.json" with { type: 'json' };

export async function getStaticPaths() {
  const applications = await getApplications('ru');
  return applications.map(a => ({
    params: { slug: a.id },
    props: { application: a }
  }));
}

const lang = 'ru';
const { application } = Astro.props;

if (!application) return Astro.redirect('/ru/resheniya-dlya-pererabotki-metalloloma');

const ui = headerI18n[lang] || headerI18n.en;
---

<BaseLayout
  lang={lang}
  currentContentId={application.content_id}
  title={application.pageTitle}
  description={application.pageDescription}
  keywords={application.pageKeywords}
>
  <ApplicationDetail lang={lang} application={application} ui={ui} />
</BaseLayout>