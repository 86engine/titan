---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CookieConsent from "../../components/CookieConsent.astro";
import { getProducts } from "../../data/products.js";
import { getApplications } from "../../data/applications.js";
import homeI18n from "../../../public/data/home-i18n.json" with { type: 'json' };

const lang = 'ru';
const prefix = lang === 'en' ? '' : `/${lang}`;
const ui = homeI18n[lang] || homeI18n.en;

const title = 'Производитель и поставщик оборудования для переработки металлов | TITAN';
const description = 'Профессиональный производитель и поставщик оборудования для переработки металлолома, поставляющий прессы, шредеры и ножницы по всему миру.';
const keywords = 'производитель оборудования для переработки металлов,поставщик оборудования для переработки металлов';

const [products, applications] = await Promise.all([
  getProducts(lang),
  getApplications(lang),
]);
const featuredProducts = products.slice(0, 4);
const featuredApplications = applications.slice(0, 6);
const productUrl = `${prefix}/metal-recycling-equipment`;
const productListSlug = 'oborudovanie-dlya-pererabotki-metallov';
const applicationListSlug = 'pererabotka-metalla';
const heroImage = 'https://img.titan-recycling.com/system/titan-recycling-systems-hero-banner.webp';
const pageTranslations = {
  en: { url: '/' },
  es: { url: '/es/' },
  ru: { url: '/ru/' },
};

const alternates = {
  en: '/',
  es: '/es/',
  ru: '/ru/',
};
---

<BaseLayout 
  lang={lang} 
  translations={pageTranslations}
  title={title} 
  description={description} 
  keywords={keywords}
  alternates={alternates}
  preloadImages={[heroImage]}
>
  <main>
    <!-- banner -->
    <section class="rs-banner-area rs-banner-three p-relative">
      <div class="rs-banner-bg-thumb">
        <img
          src={heroImage}
          alt=""
          aria-hidden="true"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </div>
      <div class="container">
        <div class="row">
          <div class="col-xl-9 col-lg-8 col-md-10">
            <div class="rs-banner-wrapper">
              <div class="rs-banner-content">
                <div class="rs-banner-border"></div>
                <h1 class="rs-banner-title wow fadeInUp" data-wow-delay=".3s" data-wow-duration=".7s">{ui.bannerTitle}</h1>
                <p style="color:var(--rs-white);font-size:24px;margin-bottom:60px;">{ui.bannerDesc}</p>
                <div class="rs-banner-btn" style="display: flex; align-items: center;">
                  <a class="rs-btn has-theme-blue has-bg has-icon" href={productUrl}>
                    {ui.bannerBtn}
                    <span class="icon-box">
                      <svg class="icon-first" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32"><path d="M31.71,15.29l-10-10L20.29,6.71,28.59,15H0v2H28.59l-8.29,8.29,1.41,1.41,10-10A1,1,0,0,0,31.71,15.29Z"/></svg>
                      <svg class="icon-second" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32"><path d="M31.71,15.29l-10-10L20.29,6.71,28.59,15H0v2H28.59l-8.29,8.29,1.41,1.41,10-10A1,1,0,0,0,31.71,15.29Z"/></svg>
                    </span>
                  </a>
                  <div class="rs-feature-video" style="margin-left: 5%;">
                    <a href="https://img.titan-recycling.com/system/video/metal-recycling-equipment-in-action.mp4" class="rs-play-btn popup-video has-theme-blue" style="width:60px; height:60px;">
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M6 4.5V13.5L13.5 9L6 4.5Z" fill="currentColor"></path></svg>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- features -->
    <section class="rs-feature-area section-space-top rs-feature-two">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-xl-8 col-lg-9 col-md-10">
            <div class="rs-section-title-wrapper text-center section-title-space">
              <h2 class="rs-section-subtitle has-theme-blue">{ui.featureSubtitle}</h2>
              <p class="rs-section-title has-theme-blue rs-split-text-enable split-in-fade" style="font-size:28px;line-height:1.5;">{ui.featureTitle}</p>
            </div>
          </div>
        </div>
        <div class="row g-5">
          {[1, 2, 3].map(n => (
            <div class="col-xl-4 col-lg-4 col-md-6">
              <div class="rs-feature-item wow fadeInUp" data-wow-delay={`.${[0.3, 0.5, 0.7][n-1]}s`} data-wow-duration="1s">
                <h3 class="rs-feature-title">{ui[`feature${n}Title`]}</h3>
                <div class="rs-feature-descrip"><p>{ui[`feature${n}Desc`]}</p></div>
                <div class="rs-feature-icon"><img src={`../assets/images/icon/feature-icon-0${n}.png`} loading="lazy" decoding="async" alt="image"></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- products swiper -->
    <section class="rs-services-area rs-services-three section-space primary-bg rs-swiper has-theme-blue" style="margin-top:110px;">
      <div class="container">
        <div class="row g-5">
          <div class="col-xl-3 col-lg-3">
            <div class="rs-services-content-wrapper">
              <div class="rs-section-title-wrapper">
                <h2 class="rs-section-subtitle has-theme-blue justify-content-start">{ui.productSubtitle}</h2>
                <p class="rs-section-title has-theme-blue rs-split-text-enable split-in-fade" style="font-size:28px;line-height:1.5;">{ui.productTitle}</p>
                <p class="descrip">{ui.productDesc}</p>
                <div class="rs-services-navigation">
                  <button class="swiper-button-prev rs-swiper-btn has-bg-white has-small hover-blue"><i class="fa-regular fa-arrow-left"></i></button>
                  <button class="swiper-button-next rs-swiper-btn has-bg-white has-small hover-blue"><i class="fa-regular fa-arrow-right"></i></button>
                </div>
              </div>
            </div>
          </div>
          <div class="col-xl-9 col-lg-9">
            <div class="rs-services-slide-wrapper process-counts">
              <div class="swiper" data-clone-slides="false" data-loop="false" data-speed="1500" data-autoplay="true" data-dots-dynamic="false" data-hover-pause="true" data-effect="false" data-delay="2500" data-item="3" data-item-xl="2" data-item-lg="2" data-item-md="2" data-item-sm="1" data-item-xs="1" data-item-mobile="1" data-margin="30" data-margin-xl="30">
                <div class="swiper-wrapper">
                  {featuredProducts.map(product => (
                    <div class="swiper-slide">
                      {(() => {
                        const productDetailUrl =
                          product.translations?.[lang]?.url && product.translations[lang].url !== '#'
                            ? product.translations[lang].url
                            : `${prefix}/${productListSlug}/${product.id}`;

                        return (
                      <div class="rs-services-item">
                        <div class="rs-services-thumb"><a href={productDetailUrl}><img src={product.productListImage} loading="lazy" decoding="async" alt={product.productName} /></a></div>
                        <div class="rs-services-content">
                          <h5 class="rs-services-title"><a href={productDetailUrl}>{product.productName}</a></h5>
                          <p class="descrip">{product.productListDescription}</p>
                          <div class="rs-services-number"></div>
                          <div class="rs-services-btn-wrapper">
                            <div class="rs-services-text-btn underline has-theme-blue"><a class="rs-text-btn" href={productDetailUrl}>{ui.viewDetail}</a></div>
                            <a class="rs-square-btn has-icon has-light-bg" href={productDetailUrl}>
                              <span class="icon-box">
                                <svg class="icon-first" xmlns="http://www.w3.org/2000/svg" width="12" height="10" viewBox="0 0 12 10" fill="none"><path fill-rule="evenodd" clip-rule="evenodd" d="M0 5C0 4.60551 0.319797 4.28571 0.714286 4.28571L8.98985 4.28571L5.92349 1.21936C5.64455 0.940417 5.64455 0.488155 5.92349 0.209209C6.20244 -0.0697365 6.6547 -0.0697365 6.93365 0.209209L11.2194 4.49492C11.4983 4.77387 11.4983 5.22613 11.2194 5.50508L6.93365 9.79079C6.6547 10.0697 6.20244 10.0697 5.92349 9.79079C5.64455 9.51184 5.64455 9.05958 5.92349 8.78064L8.98985 5.71429L0.714286 5.71429C0.319797 5.71429 0 5.39449 0 5Z" fill="#616161"/></svg>
                                <svg class="icon-second" xmlns="http://www.w3.org/2000/svg" width="12" height="10" viewBox="0 0 12 10" fill="none"><path fill-rule="evenodd" clip-rule="evenodd" d="M0 5C0 4.60551 0.319797 4.28571 0.714286 4.28571L8.98985 4.28571L5.92349 1.21936C5.64455 0.940417 5.64455 0.488155 5.92349 0.209209C6.20244 -0.0697365 6.6547 -0.0697365 6.93365 0.209209L11.2194 4.49492C11.4983 4.77387 11.4983 5.22613 11.2194 5.50508L6.93365 9.79079C6.6547 10.0697 6.20244 10.0697 5.92349 9.79079C5.64455 9.51184 5.64455 9.05958 5.92349 8.78064L8.98985 5.71429L0.714286 5.71429C0.319797 5.71429 0 5.39449 0 5Z" fill="#616161"/></svg>
                              </span>
                            </a>
                          </div>
                        </div>
                      </div>
                        );
                      })()}
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- portfolio -->
    <section class="rs-portfolio-area section-space rs-portfolio-two">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-xl-8 col-lg-6">
            <div class="rs-section-title-wrapper text-center section-title-space">
              <h2 class="rs-section-subtitle has-theme-blue">{ui.portfolioSubtitle}</h2>
              <p class="rs-section-title has-theme-blue rs-split-text-enable split-in-fade" style="font-size:28px;line-height:1.5;">{ui.portfolioTitle}</p>
            </div>
          </div>
        </div>
        <div class="row g-5">
          {featuredApplications.map(app => (
            <div class="col-xl-4 col-lg-4 col-md-6">
              {(() => {
                const appDetailUrl =
                  app.translations?.[lang]?.url && app.translations[lang].url !== '#'
                    ? app.translations[lang].url
                    : `${prefix}/${applicationListSlug}/${app.id}`;

                return (
              <div class="rs-portfolio-item wow fadeInUp" data-wow-delay=".3s" data-wow-duration="1s">
                <div class="rs-portfolio-thumb">
                  <a href={appDetailUrl}>
                    <img src={app.applicationListImage} loading="lazy" decoding="async" alt={app.applicationName}>
                  </a>
                  <div class="rs-portfolio-content">
                    <div class="rs-portfolio-tag"><a href={appDetailUrl}>{ui.solutionTag}</a></div>
                    <div class="rs-portfolio-title-info"><h5 class="rs-portfolio-title"><a href={appDetailUrl}>{app.applicationName}</a></h5></div>
                  </div>
                </div>
              </div>
                );
              })()}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- why choose -->
    <section class="rs-why-choose-area section-space rs-why-choose-one primary-bg">
      <div class="container">
        <div class="row align-items-xl-center g-5">
          <div class="col-xl-7 col-lg-7">
            <div class="rs-why-choose-content-wrapper">
              <div class="rs-section-title-wrapper section-title-space">
                <h2 class="rs-section-subtitle has-theme-blue justify-content-start">{ui.whyChooseSubtitle}</h2>
                <p class="rs-section-title has-theme-blue rs-split-text-enable split-in-fade" style="margin-right:50px;font-size:28px;line-height:1.5;">{ui.whyChooseTitle}</p>
              </div>
              <div class="rs-why-choose-item-wrapper">
                {[1, 2, 3].map(n => (
                  <div class="rs-why-choose-item">
                    <div class="rs-why-choose-icon has-white">
                      {n === 1 && (
                        <svg xmlns="http://www.w3.org/2000/svg" width="60" height="62" viewBox="0 0 60 62" fill="none"><path d="M59.9964 28.3079C59.9731 27.8377 59.5714 27.4513 59.0983 27.4513H48.7252L50.4083 23.6125C50.5029 23.3969 50.5082 23.1427 50.4228 22.9233L49.561 20.7111C50.0407 20.535 50.5058 20.32 50.9509 20.0667L53.1115 21.4029C53.511 21.6257 53.8913 21.5723 54.2524 21.243L56.3415 18.9483C56.6369 18.6239 56.6558 18.1338 56.3862 17.7875L54.8348 15.7954C55.025 15.371 55.1822 14.9334 55.3054 14.4864L57.7829 13.9144C58.2086 13.8162 58.5025 13.4268 58.4804 12.9904L58.3244 9.90244C58.3024 9.46609 57.9706 9.10848 57.5373 9.05354L55.0147 8.73427C54.8472 8.30201 54.6466 7.88261 54.4146 7.47944L55.7571 5.34122C55.9905 4.96954 55.9224 4.48379 55.5957 4.19084L53.2859 2.11837C52.9628 1.82843 52.479 1.81004 52.1347 2.07438L50.12 3.62155C49.6895 3.43126 49.2459 3.27403 48.7926 3.15142L48.2195 0.696814C48.1202 0.272125 47.7301 -0.0231006 47.2961 0.0014214L44.1854 0.158531C43.7499 0.180528 43.3926 0.511095 43.3367 0.943477L43.014 3.4434C42.5753 3.61121 42.1498 3.8122 41.7409 4.04503L39.5803 2.70882C39.2111 2.48067 38.7316 2.54763 38.4394 2.8687L36.3503 5.16343C36.0549 5.48787 36.036 5.97795 36.3057 6.32426L37.857 8.3162C37.7092 8.64628 37.5832 8.98478 37.4756 9.32893L33.2529 7.47752C32.7289 7.30418 32.3331 7.45877 32.0652 7.94115L28.4809 16.1163V2.1114C28.4809 0.945761 26.6778 0.945761 26.6778 2.1114V6.06029C20.4988 6.3215 14.7998 9.58629 11.3786 14.8486C10.7644 15.7933 12.2231 16.8576 12.8903 15.8314C15.9789 11.0807 21.1104 8.12483 26.6778 7.8647V46.0341H21.1189C20.3605 46.0341 19.7436 45.4134 19.7436 44.6503V41.5592C19.7436 41.2275 19.5615 40.9227 19.2695 40.7654C13.5322 37.6756 10.0063 31.6998 10.0679 25.1698C10.084 23.4632 10.349 21.7753 10.8557 20.1529C11.2031 19.0403 9.482 18.5026 9.1346 19.6155C8.57529 21.4064 8.2827 23.2695 8.26503 25.1529C8.19892 32.1725 11.8926 38.612 17.9407 42.0891V44.6503C17.9407 46.0935 18.9028 47.315 20.2175 47.7058V51.9767C20.2175 54.7346 