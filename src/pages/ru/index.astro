                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 2C0.895431 2 0 2.89543 0 4V12L2.58386e-05 12.0103C0.00555998 13.1101 0.898859 14 2 14H7.5C7.77614 14 8 13.7761 8 13.5C8 13.2239 7.77614 13 7.5 13H2C1.53715 13 1.14774 12.6855 1.03376 12.2586L6.67417 8.7876L8 9.5831L15 5.3831V8.5C15 8.77614 15.2239 9 15.5 9C15.7761 9 16 8.77614 16 8.5V4C16 2.89543 15.1046 2 14 2H2ZM5.70808 8.20794L1 11.1052V5.3831L5.70808 8.20794ZM1 4.2169V4C1 3.44772 1.44772 3 2 3H14C14.5523 3 15 3.44772 15 4V4.2169L8 8.4169L1 4.2169Z" fill="#6D6D6D"/><path d="M14.2467 14.2686C15.2567 14.2686 15.8339 13.4116 15.8339 12.2442V12.0344C15.8339 10.4297 14.6402 9 12.5197 9H12.4847C10.421 9 9 10.3598 9 12.4322V12.6465C9 14.8195 10.4385 16 12.3579 16H12.4016C12.9963 16 13.4204 15.9257 13.639 15.8251V15.0949C13.3941 15.2042 12.9656 15.2742 12.4585 15.2742H12.4147C11.0812 15.2742 9.84385 14.4872 9.84385 12.6202V12.4628C9.84385 10.8057 10.9019 9.73891 12.4847 9.73891H12.524C14.0587 9.73891 15.0075 10.7883 15.0075 12.065V12.183C15.0075 13.158 14.6839 13.5734 14.3691 13.5734C14.1374 13.5734 13.9582 13.4247 13.9582 13.1537V10.9631H13.0531V11.5315H13.0225C12.9394 11.2342 12.6552 10.9019 12.0693 10.9019C11.2911 10.9019 10.8101 11.4572 10.8101 12.3011V12.8301C10.8101 13.722 11.2998 14.2642 12.0693 14.2642C12.5415 14.2642 12.9656 14.0369 13.0837 13.6215H13.1274C13.2455 14.0412 13.7439 14.2686 14.2467 14.2686ZM11.7939 12.6814V12.4541C11.7939 11.9076 12.0212 11.6627 12.3666 11.6627C12.664 11.6627 12.9394 11.8551 12.9394 12.371V12.7383C12.9394 13.3111 12.6858 13.4816 12.3754 13.4816C12.0212 13.4816 11.7939 13.2673 11.7939 12.6814Z" fill="#6D6D6D"/></svg>
                      )}
                    </span></div>
                    <div class="rs-contact-list-content">
                      <span>{item.label}</span>
                      <h6><a href={item.href}>{item.value}</a></h6>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
          <div class="col-xl-5 col-lg-5">
            <div class="rs-contact-form wow fadeInUp" data-wow-delay=".3s" data-wow-duration="1s">
              <div class="rs-contact-form-bg-thumb" data-background="https://img.titan-recycling.com/wp-content/uploads/2026/04/contact-bg-03.png" style="background-image: url('https://img.titan-recycling.com/wp-content/uploads/2026/04/contact-bg-03.png');"></div>
              <h3 class="rs-contact-form-title">{ui.contactFormTitle}</h3>
              <p class="descrip">{ui.contactFormDesc}</p>
              <form
                id="contact-form"
                action="https://wp.titan-recycling.com/wp-json/api/inquiry"
                data-submit-mode="json"
                data-success-message={ui.contactFormSuccess}
                data-error-message={ui.contactFormError}
              >
                <div class="row g-4">
                  <div class="col-md-12"><div class="rs-contact-input"><input id="name" name="name" type="text" maxlength="15" required data-required-message={ui.contactFormNameRequired} placeholder={ui.contactFormName}></div></div>
                  <div class="col-md-12"><div class="rs-contact-input"><input id="email" name="email" type="email" maxlength="30" required data-required-message={ui.contactFormEmailRequired} data-invalid-message={ui.contactFormEmailInvalid} placeholder={ui.contactFormEmail}></div></div>
                  <div class="col-md-12"><div class="rs-contact-input"><input id="phone" name="phone" type="text" maxlength="15" placeholder={ui.contactFormPhone}></div></div>
                  <div class="col-md-12"><div class="rs-contact-input"><textarea id="content" name="content" maxlength="300" required data-required-message={ui.contactFormMessageRequired} placeholder={ui.contactFormMessage}></textarea></div></div>
                  <div class="col-md-12"><div class="rs-contact-btn"><button type="submit" class="rs-btn blue-bg">{ui.contactFormBtn}</button></div></div>
                </div>
                <div id="form-messages"></div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <CookieConsent lang={lang} />
</BaseLayout>
