---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AboutPage from "../../components/AboutPage.astro";
import { getAbout } from "../../data/about.js";
import headerI18n from "../../../public/data/header-i18n.json" with { type: 'json' };

const lang = 'ru';

const about = await getAbout(lang);

const ui = headerI18n[lang] || headerI18n.en;
ui.aboutLabel = { en: 'ABOUT TITAN', es: 'SOBRE TITAN', ru: 'О КОМПАНИИ' }[lang] || 'ABOUT TITAN';
ui.aboutTitle = {
  en: 'Welcome to TITAN, where advanced recycling technology meets practical solutions, helping you turn metal scrap into real value.',
  es: 'Bienvenido a TITAN, donde la tecnología de reciclaje avanzada se une a soluciones prácticas, ayudándole a convertir la chatarra en valor real.',
  ru: 'Добро пожаловать в TITAN, где передовые технологии переработки сочетаются с практическими решениями, помогая превращать металлолом в реальную ценность.'
}[lang] || '';
ui.missionTitle = { en: 'Our Mission', es: 'Nuestra Misión', ru: 'Наша Миссия' }[lang] || 'Our Mission';
ui.missionDesc = {
  en: 'To help our customers turn metal scrap into value by delivering efficient, cost-effective and reliable recycling equipment.',
  es: 'Ayudar a nuestros clientes a convertir la chatarra en valor mediante equipos de reciclaje eficientes, rentables y fiables.',
  ru: 'Помогать нашим клиентам превращать металлолом в ценность, поставляя эффективное, экономичное и надежное оборудование для переработки.'
}[lang] || '';
ui.visionTitle = { en: 'Our Vision', es: 'Nuestra Visión', ru: 'Наше Видение' }[lang] || 'Our Vision';
ui.visionDesc = {
  en: 'To be the first choice for metal recycling solutions by continuously improving technology, service and customer satisfaction.',
  es: 'Ser la primera opción en soluciones de reciclaje de metales mediante la mejora continua de la tecnología, el servicio y la satisfacción del cliente.',
  ru: 'Быть первым выбором для решений по переработке металлов, постоянно улучшая технологии, сервис и удовлетворенность клиентов.'
}[lang] || '';
---

<BaseLayout
  lang={lang}
  currentContentId="about"
  title={about.pageTitle}
  description={about.pageDescription}
  keywords={about.pageKeywords}
>
  <AboutPage lang={lang} about={about} ui={ui} />
</BaseLayout>