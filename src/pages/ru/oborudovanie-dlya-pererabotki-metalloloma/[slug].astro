---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ProductDetail from "../../../components/ProductDetail.astro";
import { getProducts } from "../../../data/products.js";
import headerI18n from "../../../../public/data/header-i18n.json" with { type: 'json' };

export async function getStaticPaths() {
  const products = await getProducts('ru');
  return products.map(p => ({
    params: { slug: p.id },
    props: { product: p }
  }));
}

const lang = 'ru';
const { product } = Astro.props;

if (!product) return Astro.redirect('/ru/oborudovanie-dlya-pererabotki-metallov');

const ui = headerI18n[lang] || headerI18n.en;
ui.download = { en: 'Download', es: 'Descargar', ru: 'Скачать' }[lang] || 'Download';
ui.requestQuote = { en: 'Request A Quote', es: 'Solicitar Cotización', ru: 'Запросить КП' }[lang] || 'Request A Quote';
ui.contactUrl = { en: '/contact#get-in-touch', es: '/es/contacto#get-in-touch', ru: '/ru/kontakty#get-in-touch' }[lang] || '/contact#get-in-touch';
---

<BaseLayout
  lang={lang}
  currentContentId={product.content_id}
  title={product.pageTitle}
  description={product.pageDescription}
  keywords={product.pageKeywords}
>
  <ProductDetail lang={lang} product={product} ui={ui} />
</BaseLayout>