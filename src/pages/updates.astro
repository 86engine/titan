---
import BaseLayout from "../layouts/BaseLayout.astro";
import UpdatesList from "../components/UpdatesList.astro";
import { getUpdates, getUpdateCategories } from "../data/updates.js";
import headerI18n from "../../public/data/header-i18n.json" with { type: 'json' };

const lang = 'en';

const [allUpdates, categories] = await Promise.all([
  getUpdates(lang),
  getUpdateCategories(lang),
]);

const ui = headerI18n[lang] || headerI18n.en;
ui.by = { en: 'By', es: 'Por', ru: 'Автор' }[lang] || 'By';
ui.continueReading = { en: 'Continue Reading', es: 'Seguir Leyendo', ru: 'Читать далее' }[lang] || 'Continue Reading';
ui.search = { en: 'Search...', es: 'Buscar...', ru: 'Поиск...' }[lang] || 'Search...';
ui.categories = { en: 'Categories', es: 'Categorías', ru: 'Категории' }[lang] || 'Categories';
ui.latestPosts = { en: 'Latest Posts', es: 'Últimas Publicaciones', ru: 'Последние записи' }[lang] || 'Latest Posts';
ui.all = { en: 'All', es: 'Todos', ru: 'Все' }[lang] || 'All';
---

<BaseLayout
  lang={lang}
  currentContentId="newsList"
  title={categories.pageTitle}
  description={categories.pageDescription}
  keywords={categories.pageKeywords}
>
  <UpdatesList lang={lang} updates={allUpdates} ui={ui} />
</BaseLayout>